# Database
DATABASE_URL=postgresql://crucible:crucible_dev@localhost:5433/crucible

# Model APIs
# In production these values must come from GCP Secret Manager.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=

# Model routing (latency-tuned defaults for MCP; see env.ts)
# MODEL_ID = synthesis, MCP framing
MODEL_ID=claude-sonnet-4-5
# EXCAVATION_MODEL = layered assumption excavation (slightly lighter than MODEL_ID)
EXCAVATION_MODEL=claude-sonnet-4-5
# ANTHROPIC_MODEL = advocate, steelman, validity judge, negative-space
ANTHROPIC_MODEL=claude-sonnet-4-5
# TEMPORAL_MODEL = temporal stack only (Haiku for latency)
TEMPORAL_MODEL=claude-haiku-4-5
ANTHROPIC_GATE_MODEL=claude-haiku-4-5
OPENAI_MODEL=gpt-4o
PERPLEXITY_MODEL=sonar-pro
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:3001
# Local: all. Production Cloud Run: api or mcp (split services — see cloudbuild.yaml)
CRUCIBLE_SERVICE_ROLE=all
# Comma-separated extra Host headers allowed for remote MCP (production DNS rebinding protection), e.g. api.example.com
MCP_ALLOWED_HOSTS=

# Security
WEBHOOK_HMAC_SECRET=
ADMIN_API_KEY=
CRUCIBLE_API_KEY=
# When set, registration requires header X-Registration-Secret (beta invite gate)
REGISTRATION_SECRET=

# Limits
FREE_TIER_DAILY_LIMIT=10
CACHE_TTL_HOURS=24
MAX_CONTENT_CHARS=50000
MAX_CONCURRENT_INTERROGATIONS=3
MAX_LOOP_ITERATIONS=4
SESSION_TTL_MINUTES=30

# GCP / Cloud Run
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_CLOUD_SQL_INSTANCE=
