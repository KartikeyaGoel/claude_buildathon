# Database
DATABASE_URL=postgresql://crucible:crucible_dev@localhost:5432/crucible

# Model APIs
# In production these values must come from GCP Secret Manager.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
PERPLEXITY_API_KEY=

# Model routing
MODEL_ID=claude-sonnet-4-20250514
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_GATE_MODEL=claude-3-5-haiku-latest
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-1.5-pro
PERPLEXITY_MODEL=sonar-pro
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:3001

# Security
WEBHOOK_HMAC_SECRET=
ADMIN_API_KEY=
CRUCIBLE_API_KEY=

# Limits
FREE_TIER_DAILY_LIMIT=10
CACHE_TTL_HOURS=24
MAX_CONTENT_CHARS=50000
MAX_CONCURRENT_INTERROGATIONS=3
MAX_LOOP_ITERATIONS=4
SESSION_TTL_MINUTES=30

# GCP / Cloud Run
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_CLOUD_SQL_INSTANCE=
