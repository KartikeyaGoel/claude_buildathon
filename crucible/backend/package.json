{
  "name": "crucible-backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "mcp:stdio": "tsx src/mcp/stdio.ts",
    "test": "vitest run",
    "typecheck": "tsc -b --pretty false",
    "ci": "npm run typecheck && npm test && npm run security:sql",
    "security:sql": "tsx src/scripts/checkSqlTemplates.ts",
    "secrets:pull": "tsx src/scripts/pullSecrets.ts",
    "jobs:refresh-percentiles": "tsx src/scripts/refreshPercentiles.ts",
    "jobs:migrate": "tsx src/scripts/runMigrations.ts",
    "export:training": "tsx src/scripts/exportTrainingData.ts",
    "migrate:up": "node-pg-migrate up --migrations-dir src/db/migrations --database-url-var DATABASE_URL",
    "migrate:down": "node-pg-migrate down --migrations-dir src/db/migrations --database-url-var DATABASE_URL",
    "migrate:create": "node-pg-migrate create --migrations-dir src/db/migrations",
    "setup": "npm install && npm run migrate:up"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@crucible/shared": "*",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^5.2.0",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^6.1.0",
    "lru-cache": "^11.3.5",
    "node-pg-migrate": "^8.0.4",
    "openai": "^6.35.0",
    "pg": "^8.13.3",
    "pino": "^10.3.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.11",
    "@types/uuid": "^10.0.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
